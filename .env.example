# コピーして .env として保存し、値を埋めてください（.env は Git に含めません）
#
# S3 Vectors: コンソールでベクトルバケットとインデックスを作成後、
# インデックスの ARN をコピーして貼り付け（リージョンは Lambda と同じに）
# インデックスのベクトル次元は 1024（Titan Embed Text v2 既定）に合わせること
VECTOR_INDEX_ARN=

# 任意: Bedrock のテキスト用推論プロファイル ID または ARN（東京例: jp.anthropic....）
# TEXT_MODEL_ID=jp.anthropic.claude-haiku-4-5-20251001-v1:0
